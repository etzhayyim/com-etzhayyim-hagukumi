;; hagukumi 育み — elder_companionship cell (Gen-3 kotoba-native)
;; ADR-2605261030 · R0 scaffold
;; Eldercare companionship sessions with cognitive + social + physical engagement,
;; encrypted attestation, and mitate co-monitoring for health changes.
{:cell/id       "elder_companionship"
 :cell/glyph    "老友"
 :cell/kind     :langgraph
 :cell/runtime  :wasm
 :cell/doc      "Eldercare companionship session handler: enrollment → baseline-health-consent → activity-attestation (encrypted, aggregate-only public fields) → social-engagement → mitate-monitoring → respite. Gates: G1 (consent) + G4 (caregiver vetting) + G5 (mitate emergency) + G9 (human co-attestation every 30 min for remote telepresence) + G15 (PII-encrypted)."

 :cell/gates    ["G1" "G4" "G5" "G9" "G15"]

 :cell/kotoba
 {:reads  [:careSessionAttestation :consentRecord :caregiverAttestation]
  :writes [:careSessionAttestation]}

 :cell/llm
 {:provider     :murakumo
  :endpoint     "127.0.0.1:4000"
  :model        "gemma3:4b"
  :charter-rider true
  :doc          "Murakumo-only. Companionship coordination (activity selection, conversation topics, engagement level) — does not diagnose or prescribe (mitate boundary)."}

 :cell/state-graph
 {:doc "LangGraph ReAct loop: enrollment → consent-verify → baseline-health → activity-plan → session-conduct → mitate-monitor → settled."
  :nodes ["enrollment" "consent_verify" "baseline_health" "activity_plan" "session_conduct" "mitate_monitor" "settled"]
  :edges [["enrollment" "consent_verify"]
          ["consent_verify" "baseline_health"]
          ["baseline_health" "activity_plan"]
          ["activity_plan" "session_conduct"]
          ["session_conduct" "mitate_monitor"]
          ["mitate_monitor" "settled"]]}
 }
