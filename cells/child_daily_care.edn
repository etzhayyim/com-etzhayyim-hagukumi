;; hagukumi 育み — child_daily_care cell (Gen-3 kotoba-native)
;; ADR-2605261030 · R0 scaffold
;; Daily childcare sessions (infants through early childhood) with privacy-first
;; encrypted attestation, consent gate, and emergency escalation to mitate.
{:cell/id       "child_daily_care"
 :cell/glyph    "日保"
 :cell/kind     :langgraph
 :cell/runtime  :wasm
 :cell/doc      "Childcare session handler: enrollment → daily care attestation (encrypted) → mealtime + play + rest cycles → respite handoff. Gates: G1 (consent) + G2 (no video) + G3 (consent window) + G4 (caregiver vetting) + G5 (emergency escalation) + G15 (PII-encrypted) + G17 (guardian consent for <14)."

 :cell/gates    ["G1" "G2" "G3" "G4" "G5" "G15" "G17"]

 :cell/kotoba
 {:reads  [:careSessionAttestation :consentRecord :caregiverAttestation]
  :writes [:careSessionAttestation]}

 :cell/llm
 {:provider     :murakumo
  :endpoint     "127.0.0.1:4000"
  :model        "gemma3:4b"
  :charter-rider true
  :doc          "Murakumo-only. Care-session coordination (schedule conflicts, caregiver capacity, enrollment eligibility) — no LLM-generated direct care instructions (human caregivers only)."}

 :cell/state-graph
 {:doc "LangGraph ReAct loop: enrollment → consent-verify → caregiver-check → daily-attestation-encrypt → mitate-emergency-check → settled."
  :nodes ["enrollment" "consent_verify" "caregiver_check" "daily_attestation_encrypt" "mitate_emergency_check" "settled"]
  :edges [["enrollment" "consent_verify"]
          ["consent_verify" "caregiver_check"]
          ["caregiver_check" "daily_attestation_encrypt"]
          ["daily_attestation_encrypt" "mitate_emergency_check"]
          ["mitate_emergency_check" "settled"]]}
 }
