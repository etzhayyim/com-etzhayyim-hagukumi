  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605261030. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "All caregiver-assistive firmware open-source WASM/Rust Apache 2.0 + Charter Rider",
      "G2": "No video stream recording (firmware-level enforcement; live telepresence permitted)",
      "G3": "1:1 per-session consent (care-recipient ≥14 or family-guardian <14); default-deny",
      "G4": "Caregiver Council vetting: background + training + ≥3 Council Lv6+ attestations",
      "G5": "Child cognitive load cap (≤2 hr structured under-6; ≤3 hr 6-12)",
      "G6": "Elder autonomy invariant (no override except immediate safety threat)",
      "G7": "No behavioral modification protocols (operant/classical/social conditioning)",
      "G8": "No advertising / no commercial-product promotion in any care setting",
      "G9": "Human-in-loop required (Yutori/Hitogata only with synchronous human caregiver)",
      "G10": "Caregiver 12-hr work cap + 12-hr recovery between shifts",
      "G11": "Emergency escalation to mitate (G5 emergency keyword shared lexicon)",
      "G12": "Charter Rider §2(d) Wellbecoming attestation quarterly per caregiver",
      "G13": "No addictive UX (gamification/streaks/variable reward/FOMO); calm-state-default",
      "G14": "Multi-generational ratio: ≥40% under-18 + ≥30% over-65 + ≤30% middle adults"
    }
  },
  "nonGoals": {
    "description": "10 explicitly excluded scopes",
    "goals": {
