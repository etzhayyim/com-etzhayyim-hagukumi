[{:db/id -1, :lex.careSessionAttestation/lexicon 1, :lex.careSessionAttestation/id "com.etzhayyim.hagukumi.careSessionAttestation", :lex.careSessionAttestation/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"tid\" \"careRecipientPseudonymDid\" \"caregiverDid\" \"sessionStartTime\" \"encryptedPayloadCid\" \"consentRecordCid\"], :properties {:tid {:type \"string\", :description \"Transaction ID\"}, :aggregatePublicFields {:type \"object\", :description \"aggregate-only, no PII: {session_duration_minutes, activity_category, emergency_triggered, mitate_escalation_level}\"}, :humanCaregiverCoAttestedEvery30Min {:type \"boolean\", :description \"For remote robotics (Yutori/Hitogata): true if human caregiver DID co-signed at session start + every 30 min (G9)\"}, :consentRecordCid {:type \"string\", :description \"IPFS CID of consent record attestation (REQUIRED per G1/G3)\"}, :careRecipientPseudonymDid {:type \"string\", :description \"30-day rotating pseudonym DID of care recipient (no stable correlation)\"}, :encryptedPayloadCid {:type \"string\", :description \"IPFS CID of XChaCha20-Poly1305 encrypted session detail (REQUIRED, no plaintext content)\"}, :sessionEndTime {:type \"string\", :description \"ISO 8601 session end (optional, for post-hoc)\"}, :sessionStartTime {:type \"string\", :description \"ISO 8601 session start\"}, :caregiverDid {:type \"string\", :description \"Caregiver DID (Council-vetted)\"}, :careType {:type \"string\", :description \"['child-daily-care' | 'elder-companionship' | 'chronic-continuity' | 'respite-support' | 'meal-coordination']\"}}}}}"}]