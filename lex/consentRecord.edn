[{:db/id -1, :lex.consentRecord/lexicon 1, :lex.consentRecord/id "com.etzhayyim.hagukumi.consentRecord", :lex.consentRecord/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"tid\" \"careRecipientPseudonymDid\" \"consentType\" \"consentTimestamp\" \"revokedAt\"], :properties {:tid {:type \"string\", :description \"Transaction ID\"}, :careRecipientPseudonymDid {:type \"string\", :description \"30-day rotating pseudonym DID\"}, :guardianDidIfUnder14 {:type \"string\", :description \"Parent/legal-guardian DID if care-recipient is <14 (REQUIRED per G17)\"}, :consentType {:type \"string\", :description \"['daily-care' | 'companionship' | 'chronic-continuity' | 'respite' | 'remote-robotics' | 'emergency-escalation-mitate']\"}, :consentTimestamp {:type \"string\", :description \"ISO 8601 when consent signed (on-chain, non-repudiable)\"}, :revokedAt {:type \"string\", :description \"ISO 8601 when consent revoked (null if active)\"}, :humanReadableSummary {:type \"string\", :description \"Natural-language consent scope (care type, duration, caregiver specialization)\"}}}}}"}]